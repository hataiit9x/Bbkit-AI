#!/usr/bin/env bash
set -euo pipefail

export BB_ROOT="${BB_ROOT:-$HOME/BugBounty}"
source "$BB_ROOT/lib/common.sh"

cmd="${1:-help}"
shift || true

case "$cmd" in
  help|-h|--help)
    cat <<'EOF'
BBKit commands:

  bb help
  bb doctor
  bb update
  bb version
  bb scope …                 # authorized engagement scope
  bb engage <program-url>    # intake + engagements/<slug>/ (CLI-first, default no scan)
  bb bounty <program-url>    # same engine; optional auto probes (use engage for Grok flow)
  bb config                  # effective config (yaml + env)
  bb dashboard [--host] [--port]
  bb browser <url>
  bb ai help | sync | doctor | run …

Recon (scope-checked when active):
  bb subs|alive|urls|js|port|nuclei|report <domain>
  bb full [options] <domain>
      --passive-only | --no-ports | --no-nuclei
      --severity LIST | --rate N | --threads N

Paths:
  $BB_ROOT/output/<domain>/
  $BB_ROOT/output/programs/
  $BB_ROOT/engagements/<slug>/   # scope.md checklist.md pipeline.md findings/ triager
  $BB_ROOT/config/config.yaml
  $BB_ROOT/ai/bug-bounty/ | web3-skills/
  $BB_ROOT/skills/bbkit/
EOF
    ;;
  scope)
    "$BB_ROOT/recon/scope" "$@"
    ;;
  engage)
    "$BB_ROOT/recon/engage" "$@"
    ;;
  config|config-show)
    "$BB_ROOT/recon/config-show" "$@"
    ;;
  dashboard)
    "$BB_ROOT/recon/dashboard" "$@"
    ;;
  bounty)
    "$BB_ROOT/recon/bounty" "$@"
    ;;
  browser)
    "$BB_ROOT/recon/browser" "$@"
    ;;
  doctor)
    "$BB_ROOT/recon/doctor"
    ;;
  update)
    "$BB_ROOT/recon/update"
    ;;
  version)
    "$BB_ROOT/recon/version"
    ;;
  ai)
    subcmd="${1:-help}"
    shift || true
    case "$subcmd" in
      help|-h|--help)
        cat <<'EOF'
BBKit AI commands:

  bb ai sync                 Sync Claude/Codex/.agents + web3 skills + bbkit skill
  bb ai doctor               Check AI bundle and harness paths
  bb ai run <tool> [args...] Run a bundled Claude Bug Bounty tool from BBKit
EOF
        ;;
      sync)
        "$BB_ROOT/recon/ai-sync" "$@"
        ;;
      doctor)
        "$BB_ROOT/recon/ai-doctor" "$@"
        ;;
      run)
        "$BB_ROOT/recon/ai-run" "$@"
        ;;
      *)
        err "Unknown AI command: $subcmd"
        echo "Run: bb ai help"
        exit 1
        ;;
    esac
    ;;
  hunt|validate|intel|scan-cves|arsenal)
    "$BB_ROOT/recon/$cmd" "$@"
    ;;
  subs|alive|urls|js|port|nuclei|report|full)
    "$BB_ROOT/recon/$cmd" "$@"
    ;;
  # allow recon/config-show via full name if invoked oddly
  config-show)
    "$BB_ROOT/recon/config-show" "$@"
    ;;
  *)
    err "Unknown command: $cmd"
    echo "Run: bb help"
    exit 1
    ;;
esac
