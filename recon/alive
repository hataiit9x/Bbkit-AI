#!/usr/bin/env bash
set -euo pipefail
source "$BB_ROOT/lib/common.sh"
require_target "${1:-}"
target="$1"
require_in_scope "$target"
base="$BB_OUTPUT/$target"
subs="$base/subs/resolved.txt"
out="$base/alive"
mkdir -p "$out"

[[ -f "$subs" ]] || "$BB_ROOT/recon/subs" "$target"

if need_cmd httpx; then
  hx_args=(-l "$subs" -silent -status-code -content-length -title -tech-detect -follow-redirects -o "$out/httpx.txt")
  hx_args+=(-threads "${BB_HTTPX_THREADS:-$BB_THREADS}")
  if [[ -n "${BB_RATE:-}" ]]; then hx_args+=(-rate-limit "$BB_RATE"); fi
  httpx "${hx_args[@]}" || true
  awk '{print $1}' "$out/httpx.txt" | sort -u > "$out/alive.txt" || true
else
  cp "$subs" "$out/alive.txt"
fi

log "Saved: $out/alive.txt"
