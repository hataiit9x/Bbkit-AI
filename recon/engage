#!/usr/bin/env bash
# CLI-first program intake for Grok Build / agents.
# Creates engagements/<slug>/ (scope, checklist, pipeline, findings, triager)
# and activates scope. Default: no noisy auto scan (save tokens).
set -euo pipefail
source "$BB_ROOT/lib/common.sh"

usage() {
  cat <<'EOF'
Usage:
  bb engage <program-url> [options]

Create engagement workspace from a bounty program page (Cantina, Immunefi, H1, …).

Options:
  --slug NAME              Engagement folder under engagements/ (e.g. rogo-recon)
  --browser auto|off|standard   Page fetch / CloakBrowser (default: auto)
  --timeout N              HTTP / browser timeout seconds
  --scan                   Also run scoped web probes (alive/urls/nuclei when applicable)
  --max-targets N          Cap auto targets if --scan
  --no-engage              Intake files only under output/programs/ (no engagements/)

Default behavior: --intake-only (scope + checklist + activate; no auto nuclei).

Examples:
  bb engage 'https://cantina.xyz/code/.../overview'
  bb engage 'https://cantina.xyz/code/.../overview' --slug rogo-recon
  bb engage 'https://immunefi.com/bug-bounty/foo/' --scan

Next steps (for AI / operator):
  1. Read engagements/<slug>/scope.md + checklist.md + pipeline.md
  2. Run CLI tools listed in pipeline.md (bb alive / urls / … or Foundry)
  3. Write findings under engagements/<slug>/findings/ + poc/
  4. Fill triager-review.md before submit
EOF
}

if [[ $# -lt 1 || "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  usage
  exit 0
fi

scan=0
args=()
for a in "$@"; do
  if [[ "$a" == "--scan" ]]; then
    scan=1
  else
    args+=("$a")
  fi
done

if [[ $scan -eq 1 ]]; then
  exec python3 "$BB_ROOT/lib/program_hunt.py" "${args[@]}"
else
  exec python3 "$BB_ROOT/lib/program_hunt.py" --intake-only "${args[@]}"
fi
