#!/usr/bin/env bash
set -euo pipefail
source "$BB_ROOT/lib/common.sh"
require_target "${1:-}"
target="$1"
require_in_scope "$target"
base="$BB_OUTPUT/$target"
alive="$base/alive/alive.txt"
out="$base/nuclei"
mkdir -p "$out"

[[ -f "$alive" ]] || "$BB_ROOT/recon/alive" "$target"

if need_cmd nuclei; then
  sev="${BB_NUCLEI_SEVERITY:-critical,high,medium}"
  n_args=(-l "$alive" -severity "$sev" -o "$out/nuclei.txt")
  if [[ -n "${BB_RATE:-}" ]]; then n_args+=(-rate-limit "$BB_RATE"); fi
  if [[ -n "${BB_THREADS:-}" ]]; then n_args+=(-c "$BB_THREADS"); fi
  nuclei "${n_args[@]}" || true
fi

log "Saved: $out/nuclei.txt"
